<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>TurboMediator.Scheduling.EntityFramework</RootNamespace>

    <!-- Package Info -->
    <PackageId>TurboMediator.Scheduling.EntityFramework</PackageId>
    <Description>Entity Framework Core provider for TurboMediator.Scheduling - persistent job store with EF Core</Description>
    <PackageTags>mediator;cqrs;scheduling;cron;efcore;entityframework</PackageTags>

    <!-- Documentation -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TurboMediator.Scheduling\TurboMediator.Scheduling.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" Version="8.0.0" />
  </ItemGroup>

</Project>
